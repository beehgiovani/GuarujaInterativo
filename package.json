{
    "name": "guaruja-geomap",
    "version": "1.0.0",
    "description": "Plataforma de Inteligência Imobiliária do Guarujá",
    "main": "mapa_interativo/electron-main.js",
    "scripts": {
        "start": "node index.js",
        "dev": "node --watch index.js",
        "electron": "electron mapa_interativo/electron-main.js",
        "dist": "electron-builder -w",
        "release": "python automate_release.py",
        "test": "node tests/test_runner.js"
    },
    "keywords": [],
    "author": "Omega Imóveis",
    "license": "ISC",
    "dependencies": {
        "@capacitor/android": "^8.0.2",
        "@capacitor/camera": "^8.0.0",
        "@capacitor/cli": "^8.0.2",
        "@capacitor/core": "^8.0.2",
        "@ionic/pwa-elements": "^3.3.0",
        "@supabase/supabase-js": "^2.99.1",
        "dotenv": "^16.3.1",
        "electron-log": "^5.4.3",
        "electron-updater": "^6.7.3",
        "imap-simple": "^5.1.0",
        "mailparser": "^3.6.5",
        "node-fetch": "^2.7.0",
        "nodemailer": "^6.9.7"
    },
    "devDependencies": {
        "electron": "^28.0.0",
        "electron-builder": "^24.9.1",
        "supabase": "^2.78.1"
    },
    "build": {
        "productName": "Guaruja GeoMap",
        "appId": "com.omegaimoveis.guarugeo",
        "win": {
            "icon": "mapa_interativo/logo.png"
        },
        "directories": {
            "output": "dist"
        },
        "files": [
            "mapa_interativo/**/*",
            "package.json"
        ],
        "publish": {
            "provider": "generic",
            "url": "https://mapaguaruja-eb395.web.app/downloads/"
        }
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/beehgiovani/GuaruGeo.git"
    }
}
